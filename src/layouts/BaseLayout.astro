---
/**
 * @file BaseLayout.astro
 * @description Root HTML document shell. Configures global styling, SEO metadata, and JSON-LD schema.
 */

import '../styles/global.css';
import Analytics from '@vercel/analytics/astro';

/**
 * Component properties for the BaseLayout.
 */
interface Props {
	/** The document title shown in browser tab headers and search index headlines. */
	title: string;
	/** The meta description summary for SEO search engine result snippets. */
	description: string;
	/** Optional URL path for the Open Graph sharing image snippet. Defaults to '/default-og.png'. */
	ogImage?: string;
	/** 
	 * Optional flag to add a 'noindex, follow' robots directive. 
	 * Used for in-development pages that shouldn't be indexed but whose link equity should be followed.
	 */
	noindex?: boolean;
}

const { title, description, ogImage, noindex = false } = Astro.props;
const cleanPathname = Astro.url.pathname.replace(/\/$/, '') || '/';
const canonicalURL = new URL(cleanPathname, Astro.site || Astro.url.origin);
const resolvedOgImage = new URL(ogImage || '/default-og.png', Astro.site || Astro.url.origin).toString();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/ph.svg" />
		<meta name="generator" content={Astro.generator} />

		{noindex && (
			/* 
				SEO Strategy: "noindex, follow" tells crawlers (like Googlebot) not to show 
				this page in search results (preventing thin-content or placeholder penalties), 
				but still allows them to crawl/follow links to preserve internal link equity (link juice).
			*/
			<meta name="robots" content="noindex, follow" />
		)}

		<!-- Google AdSense / Site Verification -->
		<script is:inline async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client=ca-pub-7494033520495523" crossorigin="anonymous"></script>

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={resolvedOgImage} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={resolvedOgImage} />

		<slot name="schema" />
	</head>
	<body class="bg-mapa-canvas text-mapa-ink min-h-screen">
		<slot />
		<Analytics />
	</body>
</html>
