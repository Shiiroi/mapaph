---
/**
 * @file BaseLayout.astro
 * @description Root HTML document shell. Configures global styling, SEO metadata, and JSON-LD schema.
 */

import '../styles/global.css';

/**
 * Component properties for the BaseLayout.
 */
interface Props {
	/** The document title shown in browser tab headers and search index headlines. */
	title: string;
	/** The meta description summary for SEO search engine result snippets. */
	description: string;
	/** Optional URL path for the Open Graph sharing image snippet. Defaults to '/default-og.png'. */
	ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url.origin);
const resolvedOgImage = ogImage || new URL('/default-og.png', Astro.url.origin).toString();
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/PH.svg" />
		<link rel="icon" type="image/png" href="/PH.png" />
		<meta name="generator" content={Astro.generator} />

		<!-- Primary Meta Tags -->
		<title>{title}</title>
		<meta name="title" content={title} />
		<meta name="description" content={description} />
		<link rel="canonical" href={canonicalURL} />

		<!-- Open Graph / Facebook -->
		<meta property="og:type" content="website" />
		<meta property="og:url" content={canonicalURL} />
		<meta property="og:title" content={title} />
		<meta property="og:description" content={description} />
		<meta property="og:image" content={resolvedOgImage} />

		<!-- Twitter -->
		<meta property="twitter:card" content="summary_large_image" />
		<meta property="twitter:url" content={canonicalURL} />
		<meta property="twitter:title" content={title} />
		<meta property="twitter:description" content={description} />
		<meta property="twitter:image" content={resolvedOgImage} />

		<!-- JSON-LD Schema Markup -->
		<script type="application/ld+json" is:inline>
			{
				"@context": "https://schema.org",
				"@graph": [
					{
						"@type": "WebSite",
						"name": "mapaPH",
						"url": "https://mapaph.com",
						"description": "Open-source mapping tools for the Philippines"
					},
					{
						"@type": "ItemList",
						"name": "mapaPH Tools Directory",
						"description": "Suite of mapping, routing, and directory applications for the Philippines.",
						"itemListElement": [
							{
								"@type": "ListItem",
								"position": 1,
								"item": {
									"@type": "WebApplication",
									"name": "Lens",
									"url": "https://lens.mapaph.com",
									"description": "An interactive visualizer that overlays civic data on Philippine regional maps using color-coded choropleth maps, enabling detailed demographic and socioeconomic analysis."
								}
							},
							{
								"@type": "ListItem",
								"position": 2,
								"item": {
									"@type": "WebApplication",
									"name": "To-Cubao",
									"url": "https://to-cubao.mapaph.com",
									"description": "A commute and transit routing application tailored for Metro Manila commuters, helping plan optimal public utility vehicle paths and travel times to Cubao and surrounding hubs."
								}
							},
							{
								"@type": "ListItem",
								"position": 3,
								"item": {
									"@type": "WebApplication",
									"name": "Pet friendly",
									"url": "https://pet-friendly.mapaph.com",
									"description": "A collaborative community directory indexing dog-friendly and cat-friendly establishments, parks, and restaurants across the Philippines, detailing pet policies and rules."
								}
							}
						]
					}
				]
			}
		</script>
	</head>
	<body class="bg-mapa-canvas text-mapa-ink min-h-screen">
		<slot />
	</body>
</html>
