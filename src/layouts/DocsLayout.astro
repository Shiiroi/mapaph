---
/**
 * @file DocsLayout.astro
 * @description Docs layout shell — Navbar on top, sticky left sidebar, scrollable content column.
 */

import BaseLayout from './BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	description: string;
	activeSlug: 'index' | 'lens' | 'to-cubao';
	/**
	 * Optional flag to add 'noindex, follow' robots directive.
	 * Used for in-development pages that shouldn't be indexed yet.
	 */
	noindex?: boolean;
}

const { title, description, activeSlug, noindex = false } = Astro.props;

const tools = [
	{ name: 'Lens',         slug: 'lens',         url: '/docs/lens',         active: true  },
	{ name: 'To-Cubao',     slug: 'to-cubao',     url: '/docs/to-cubao',     active: false },
];

// Ordered page list for prev/next navigation
const pages = [
	{ slug: 'index',        name: 'Overview',      url: '/docs'              },
	{ slug: 'lens',         name: 'Lens',          url: '/docs/lens'         },
	{ slug: 'to-cubao',     name: 'To-Cubao',      url: '/docs/to-cubao'     },
];
const currentIndex = pages.findIndex(p => p.slug === activeSlug);
const prevPage = currentIndex > 0 ? pages[currentIndex - 1] : null;
const nextPage = currentIndex < pages.length - 1 ? pages[currentIndex + 1] : null;
---

<BaseLayout title={title} description={description} noindex={noindex}>
	<Navbar />

	<!-- Outer wrapper: border under navbar -->
	<div style="border-top: 1px solid rgba(0,0,0,0.08);">

		<!-- Two-column layout -->
		<div style="display: flex; min-height: calc(100vh - 4rem);">

			<!-- ====== LEFT SIDEBAR ====== -->
			<div style="width: 220px; flex-shrink: 0;">
				<div style="position: sticky; top: 4rem; height: calc(100vh - 4rem); overflow-y: auto; border-right: 1px solid rgba(0,0,0,0.08);">
					<div style="padding: 2.5rem 1.75rem 2rem 1.5rem;">

						<!-- SECTION: NAVIGATE -->
						<p class="font-sans text-mapa-green" style="font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.6rem;">
							Navigate
						</p>
						<a
							href="/docs"
							class={`font-sans flex items-center gap-2 ${activeSlug === 'index' ? 'text-mapa-green font-semibold' : 'text-mapa-ink/60 hover:text-mapa-ink'}`}
							style="font-size: 0.875rem; padding: 0.375rem 0; display: flex; align-items: center; gap: 0.5rem;"
						>
							{activeSlug === 'index'
								? <span style="width: 6px; height: 6px; border-radius: 50%; background: currentColor; flex-shrink: 0;"></span>
								: <span style="width: 6px; height: 6px; flex-shrink: 0;"></span>
							}
							Overview
						</a>

						<!-- SECTION: TOOLS -->
						<p class="font-sans text-mapa-green" style="font-size: 10px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; margin-top: 2rem; margin-bottom: 0.6rem;">
							Tools
						</p>
						<nav style="display: flex; flex-direction: column;">
							{tools.map(tool => {
								const isActive = activeSlug === tool.slug;
								return (
									<a
										href={tool.url}
										class={`font-sans ${isActive ? 'text-mapa-green font-semibold' : tool.active ? 'text-mapa-ink/60 hover:text-mapa-ink' : 'text-mapa-ink/35 hover:text-mapa-ink/60'}`}
										style="font-size: 0.875rem; padding: 0.375rem 0; display: flex; align-items: center; justify-content: space-between;"
									>
										<span style="display: flex; align-items: center; gap: 0.5rem;">
											{isActive
												? <span style="width: 6px; height: 6px; border-radius: 50%; background: currentColor; flex-shrink: 0;"></span>
												: <span style="width: 6px; height: 6px; flex-shrink: 0;"></span>
											}
											{tool.name}
										</span>
										{!tool.active && (
											<span class="font-sans text-mapa-ink/45" style="font-size: 8px; letter-spacing: 0.08em; text-transform: uppercase; background: rgba(0,0,0,0.06); padding: 2px 6px; border-radius: 3px;">
												Dev
											</span>
										)}
									</a>
								);
							})}
						</nav>

					</div>
				</div>
			</div>

			<!-- ====== MAIN CONTENT ====== -->
			<main style="flex: 1; min-width: 0;">
				<div style="max-width: 48rem; padding: 2.5rem 3rem 2rem 3.5rem;">
					<slot />
				</div>

				<!-- PREV / NEXT NAVIGATION -->
				<div style="max-width: 48rem; padding: 0 3rem 6rem 3.5rem; margin-top: 2rem;">
					<div style="border-top: 1px solid rgba(0,0,0,0.08); padding-top: 2rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem;">
						<!-- PREV -->
						{prevPage ? (
							<a href={prevPage.url} class="group font-sans text-mapa-ink/60 hover:text-mapa-green" style="display: flex; flex-direction: column; gap: 0.25rem; text-decoration: none; transition: color 0.15s;">
								<span style="font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; opacity: 0.5;">← Previous</span>
								<span class="font-sans font-semibold" style="font-size: 0.9rem;">{prevPage.name}</span>
							</a>
						) : <span></span>}

						<!-- NEXT -->
						{nextPage ? (
							<a href={nextPage.url} class="group font-sans text-mapa-ink/60 hover:text-mapa-green" style="display: flex; flex-direction: column; align-items: flex-end; gap: 0.25rem; text-decoration: none; transition: color 0.15s;">
								<span style="font-size: 10px; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; opacity: 0.5;">Next →</span>
								<span class="font-sans font-semibold" style="font-size: 0.9rem;">{nextPage.name}</span>
							</a>
						) : <span></span>}
					</div>
				</div>
			</main>

		</div>
	</div>

	<Footer />
</BaseLayout>
