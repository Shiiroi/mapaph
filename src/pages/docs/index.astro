---
import DocsLayout from '../../layouts/DocsLayout.astro';
---

<DocsLayout
	title="Documentation: mapaPH"
	description="Explore user guides, data resources, and documentation for mapaPH open-source mapping tools."
	activeSlug="index"
>
	<span class="font-sans text-xs font-bold uppercase tracking-wider text-mapa-green">Documentation</span>

	<h1 class="text-4xl font-extrabold text-mapa-green tracking-tight sm:text-5xl font-serif mt-2">
		mapaPH Documentation
	</h1>

	<p class="mt-4 text-lg text-mapa-ink/80 italic leading-relaxed font-serif">
		Guides, data references, and documentation for our open-source mapping tools.
	</p>

	<div class="mt-10 border-t border-mapa-contour/60 pt-8 flex flex-col gap-10">

		<!-- Lens -->
		<div>
			<div class="flex items-center gap-3 mb-2">
				<h2 class="text-xl sm:text-2xl font-bold text-mapa-ink font-serif">
					<a href="/docs/lens" class="hover:text-mapa-green transition-colors duration-200">
						Lens Documentation
					</a>
				</h2>
				<span class="font-sans text-[10px] font-bold uppercase tracking-wider bg-mapa-green/10 text-mapa-green px-2.5 py-0.5 rounded">
					Active
				</span>
			</div>
			<p class="font-sans text-sm text-mapa-ink/90 leading-relaxed">
				User guide and documentation for Lens, our interactive map viewer and GeoJSON export utility for Philippine administrative divisions.
			</p>
			<a href="/docs/lens" class="font-sans text-xs font-semibold text-mapa-green hover:underline mt-2.5 inline-block">
				Read Guide &rarr;
			</a>
		</div>

		<!-- To-Cubao -->
		<div class="border-t border-mapa-contour/40 pt-8">
			<div class="flex items-center gap-3 mb-2">
				<h2 class="text-xl sm:text-2xl font-bold text-mapa-ink/60 font-serif">
					<a href="/docs/to-cubao" class="hover:text-mapa-green transition-colors duration-200">
						To-Cubao Documentation
					</a>
				</h2>
				<span class="font-sans text-[10px] font-bold uppercase tracking-wider bg-mapa-clay/30 text-mapa-ink/60 px-2.5 py-0.5 rounded">
					In Development
				</span>
			</div>
			<p class="font-sans text-sm text-mapa-ink/70 leading-relaxed">
				Documentation for our proposed transit routing and terminal locator tool for the Cubao hub.
			</p>
			<a href="/docs/to-cubao" class="font-sans text-xs font-semibold text-mapa-green hover:underline mt-2.5 inline-block">
				View Project Status &rarr;
			</a>
		</div>

		<!-- Pet Friendly -->
		<div class="border-t border-mapa-contour/40 pt-8">
			<div class="flex items-center gap-3 mb-2">
				<h2 class="text-xl sm:text-2xl font-bold text-mapa-ink/60 font-serif">
					<a href="/docs/pet-friendly" class="hover:text-mapa-green transition-colors duration-200">
						Pet Friendly Documentation
					</a>
				</h2>
				<span class="font-sans text-[10px] font-bold uppercase tracking-wider bg-mapa-clay/30 text-mapa-ink/60 px-2.5 py-0.5 rounded">
					In Development
				</span>
			</div>
			<p class="font-sans text-sm text-mapa-ink/70 leading-relaxed">
				Documentation for our proposed directory mapping animal-welcoming parks, cafes, and establishments.
			</p>
			<a href="/docs/pet-friendly" class="font-sans text-xs font-semibold text-mapa-green hover:underline mt-2.5 inline-block">
				View Project Status &rarr;
			</a>
		</div>

	</div>
</DocsLayout>
