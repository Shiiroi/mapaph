---

---

<header class="sticky top-0 z-50 bg-mapa-canvas border-b border-mapa-contour">
	<div class="max-w-7xl mx-auto px-6 lg:px-8">
		<div class="flex items-center justify-between h-16">
			<!-- Left: Logo & Wordmark -->
			<a href="/" class="flex items-center gap-2 sm:gap-2.5 group">
				<img
					src="/ph.svg"
					alt="mapaPH Logo"
					class="w-8 h-8 object-contain transition-transform duration-200 group-hover:scale-105"
				/>
				<span
					class="font-serif font-bold text-lg tracking-tight text-mapa-ink group-hover:text-mapa-green transition-colors duration-200"
				>
					mapaPH
				</span>
			</a>

			<!-- Right: Nav Links -->
			<nav class="flex items-center gap-3 sm:gap-6 md:gap-8">
				<a
					href="/about"
					class="font-sans text-sm font-medium text-mapa-ink hover:text-mapa-green transition-colors duration-200"
					>About</a
				>
				<a
					href="/docs"
					class="font-sans text-sm font-medium text-mapa-ink hover:text-mapa-green transition-colors duration-200"
					>Docs</a
				>
				<a
					href="https://github.com/Shiiroi/mapaph"
					target="_blank"
					rel="noopener noreferrer"
					class="font-sans text-sm font-medium text-mapa-ink hover:text-mapa-green transition-colors duration-200 flex items-center gap-1.5"
				>
					<span>GitHub</span>
				</a>
			</nav>
		</div>
	</div>
</header>
