---
const tools = [
	{
		name: "Lens",
		category: "Map",
		status: "Live",
		statusColor: "bg-emerald-100 text-emerald-800 border-emerald-200/50",
		statusDot: "bg-emerald-500",
		url: "https://lens.mapaph.com",
		description: "An interactive visualizer that overlays civic data on Philippine regional maps using color-coded choropleth maps, enabling detailed demographic and socioeconomic analysis.",
		// magnifying glass over map/grid
		svg: `<svg class="w-6 h-6 text-mapa-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
			<path stroke-linecap="round" stroke-linejoin="round" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7" />
			<circle cx="15" cy="10" r="3" stroke="currentColor" stroke-width="2" />
			<path stroke-linecap="round" stroke-linejoin="round" d="M17.5 12.5L20 15" />
		</svg>`
	},
	{
		name: "To-Cubao",
		category: "Routing",
		status: "In development",
		statusColor: "bg-amber-100 text-amber-800 border-amber-200/50",
		statusDot: "bg-amber-500",
		url: "https://to-cubao.mapaph.com",
		description: "A commute and transit routing application tailored for Metro Manila commuters, helping plan optimal public utility vehicle paths and travel times to Cubao and surrounding hubs.",
		// route pin
		svg: `<svg class="w-6 h-6 text-mapa-clay" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
			<path stroke-linecap="round" stroke-linejoin="round" d="M9 6a3 3 0 11-6 0 3 3 0 016 0zM17 6a3 3 0 11-6 0 3 3 0 016 0zM9 18a3 3 0 11-6 0 3 3 0 016 0zM17 18a3 3 0 11-6 0 3 3 0 016 0z" />
			<path stroke-linecap="round" stroke-linejoin="round" d="M6 9v6M14 9v6" />
		</svg>`
	},
	{
		name: "Pet friendly",
		category: "Directory",
		status: "In development",
		statusColor: "bg-slate-100 text-slate-700 border-slate-200/50",
		statusDot: "bg-slate-400",
		url: "https://pet-friendly.mapaph.com",
		description: "A collaborative community directory indexing dog-friendly and cat-friendly establishments, parks, and restaurants across the Philippines, detailing pet policies and rules.",
		svg: `<svg class="w-6 h-6 text-mapa-ink" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
			<path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
		</svg>`
	}
];
---

<section class="mt-20">
	<div class="border-b border-mapa-contour pb-4 mb-8">
		<h2 class="font-serif text-3xl font-extrabold text-mapa-green tracking-tight">Hub Directory</h2>
		<p class="font-sans text-sm text-mapa-clay mt-1">Explore our current, upcoming, and proposed mapping applications.</p>
	</div>

	<div class="grid grid-cols-1 md:grid-cols-3 gap-6">
		{tools.map((tool) => (
			<a 
				href={tool.url} 
				target="_blank" 
				rel="noopener noreferrer" 
				class="block p-6 rounded-lg bg-mapa-canvas border border-mapa-clay/30 hover:border-mapa-clay hover:-translate-y-1 hover:shadow-md hover:shadow-mapa-clay/5 transition-all duration-300 group cursor-pointer"
			>
				<div class="flex items-start justify-between gap-4">
					<!-- Icon / Thumbnail Area -->
					<div class="w-12 h-12 rounded-md bg-mapa-contour/20 flex items-center justify-center border border-mapa-contour/30 group-hover:bg-mapa-contour/30 transition-colors duration-300">
						<Fragment set:html={tool.svg} />
					</div>
					
					<!-- Status Pill -->
					<span class={`inline-flex items-center gap-1.5 px-2.5 py-0.5 rounded-full text-xs font-semibold font-sans border ${tool.statusColor}`}>
						<span class={`w-1.5 h-1.5 rounded-full ${tool.statusDot}`}></span>
						{tool.status}
					</span>
				</div>

				<div class="mt-5">
					<span class="font-sans text-xs font-bold tracking-wider uppercase text-mapa-clay">
						{tool.category}
					</span>
					<h3 class="font-serif text-xl font-bold text-mapa-ink mt-1 group-hover:text-mapa-green transition-colors duration-200">
						{tool.name}
					</h3>
					<p class="font-sans text-sm text-mapa-ink/80 mt-2.5 leading-relaxed">
						{tool.description}
					</p>
				</div>
			</a>
		))}
	</div>
</section>
