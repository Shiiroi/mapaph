---
// src/components/ToolsSection.astro

const tools = [
	{
		name: "Lens",
		status: "Active",
		category: "Data",
		url: "https://lens.mapaph.com",
		github: "https://github.com/Shiiroi/mapaph",
		description: "An interactive visualizer that projects civic data onto regional maps. Allows downloading Philippine GeoJSON boundary files, along with statistics like GDP, pollution, density, and local assets.",
		image: "/lens.png",
		hasImage: true
	},
	{
		name: "To-Cubao",
		status: "In Development",
		category: "Routing",
		url: "https://to-cubao.mapaph.com",
		github: "https://github.com/Shiiroi/mapaph",
		description: "A transit router mapping commute paths, public utility vehicle routes, and estimated transit times to Cubao and surrounding Metro Manila hubs.",
		image: null,
		hasImage: false
	},
	{
		name: "Pet Friendly",
		status: "In Development",
		category: "Directory",
		url: "https://pet-friendly.mapaph.com",
		github: "https://github.com/Shiiroi/mapaph",
		description: "A crowdsourced directory mapping animal-welcoming parks, cafes, and establishments, indexing pet policies and rules nationwide.",
		image: null,
		hasImage: false
	}
];
---

<section id="tools" class="max-w-7xl mx-auto px-6 lg:px-8 py-16 md:py-24">
	<!-- Section Header -->
	<div class="border-b border-mapa-contour/50 pb-5 mb-10 font-serif">
		<h2 class="text-3xl font-extrabold text-mapa-ink tracking-tight">
			The Directory
		</h2>
		<p class="font-sans text-sm text-mapa-clay mt-1">
			A catalog of open-source applications using maps of the Philippines.
		</p>
	</div>

	<!-- Card Grid -->
	<div class="grid grid-cols-1 md:grid-cols-3 gap-8 font-sans">
		{tools.map((tool) => (
			<div
				class="flex flex-col bg-mapa-canvas border border-mapa-contour/80 rounded-lg overflow-hidden hover:border-mapa-clay hover:-translate-y-1 transition-all duration-300 group relative cursor-pointer"
			>
				<!-- Card Link Overlay: makes the entire card clickable without nested anchors -->
				<a
					href={tool.url}
					target="_blank"
					rel="noopener noreferrer"
					class="absolute inset-0 z-10"
					aria-label={`Visit ${tool.name}`}
				/>

				<!-- Card Preview Container -->
				<div class="block border-b border-mapa-contour/50 overflow-hidden relative z-0">
					{tool.hasImage ? (
						<img
							src={tool.image}
							alt={`${tool.name} screenshot`}
							class="w-full h-48 object-cover object-top transition-transform duration-500 group-hover:scale-105"
							loading="lazy"
						/>
					) : (
						<div class="h-48 bg-mapa-canvas-dark flex items-center justify-center transition-colors duration-500 group-hover:bg-mapa-contour/30">
							<span class="font-sans text-sm font-semibold text-mapa-clay/60 tracking-wider uppercase select-none transition-transform duration-500 group-hover:scale-105">Coming Soon</span>
						</div>
					)}
				</div>

				<!-- Card Body -->
				<div class="p-6 flex flex-col flex-grow">
					<!-- Badges -->
					<div class="flex flex-wrap items-center gap-2 mb-4">
						<span class="uppercase text-[9px] font-bold tracking-wider px-2.5 py-0.5 rounded bg-mapa-contour/50 border border-mapa-contour text-mapa-ink/75 select-none">
							{tool.category}
						</span>
						<span class={`uppercase text-[9px] font-bold tracking-wider px-2.5 py-0.5 rounded border select-none ${
							tool.status === "Active"
								? "bg-mapa-green/10 border-mapa-green/35 text-mapa-green"
								: "bg-mapa-clay/10 border-mapa-clay/35 text-mapa-clay"
						}`}>
							{tool.status}
						</span>
					</div>

					<!-- Tool Name & Description -->
					<h3 class="font-serif text-xl font-bold text-mapa-ink">
						{tool.name}
					</h3>
					
					<p class="text-xs sm:text-sm text-mapa-ink/80 mt-2.5 leading-relaxed flex-grow">
						{tool.description}
					</p>

					<!-- Actions: GitHub Icon only (placed at the bottom right, relative z-20 to allow direct click) -->
					<div class="flex items-center justify-end mt-6 pt-4 border-t border-mapa-contour/40">
						<a
							href={tool.github}
							target="_blank"
							rel="noopener noreferrer"
							class="relative z-20 text-mapa-ink/40 hover:text-mapa-ink/80 active:text-mapa-ink active:scale-95 transform transition-all duration-200"
							aria-label={`${tool.name} on GitHub`}
						>
							<svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
								<path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z" />
							</svg>
						</a>
					</div>
				</div>
			</div>
		))}
	</div>
</section>
