---
/**
 * @file LatestUpdates.astro
 * @description Manual project changelog section highlighting active development across the ecosystem.
 */

import changelog from "../data/changelog.json";
---

<section
	id="updates"
	class="bg-mapa-canvas-dark border-t border-mapa-contour/60 py-16 md:py-24 font-serif"
>
	<div class="max-w-7xl mx-auto px-6 lg:px-8">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
			<!-- Left Column: Title / Header -->
			<div class="lg:col-span-4 flex flex-col justify-start">
				<div class="flex items-center gap-2 mb-4">
					<span
						class="font-sans text-xs font-bold uppercase tracking-wider text-mapa-green"
					>
						Activity Log
					</span>
				</div>
				<h2
					class="text-3xl sm:text-4xl font-extrabold text-mapa-ink leading-tight"
				>
					Latest Updates & Releases
				</h2>
				<p class="font-sans text-sm text-mapa-ink/80 mt-4 leading-relaxed">
					Follow the latest progress, releases, and development milestones
					across all open-source tools in the mapaPH ecosystem.
				</p>
			</div>

			<!-- Right Column: Timeline list -->
			<div class="lg:col-span-8">
				<div class="flow-root font-sans">
					<ul class="-mb-8">
						{
							changelog.map((entry, entryIdx) => (
								<li>
									<div class="relative pb-8">
										{entryIdx !== changelog.length - 1 ? (
											<span
												class="absolute top-5 left-5 -ml-px h-full w-0.5 bg-mapa-contour"
												aria-hidden="true"
											/>
										) : null}
										<div class="relative flex items-start space-x-3">
											<!-- Timeline node dot -->
											<div class="relative">
												<span class="flex h-10 w-10 items-center justify-center rounded-full bg-mapa-green text-mapa-canvas ring-8 ring-mapa-canvas-dark">
													<svg
														xmlns="http://www.w3.org/2000/svg"
														fill="none"
														viewBox="0 0 24 24"
														stroke-width="2.5"
														stroke="currentColor"
														class="h-4.5 w-4.5"
													>
														<path
															stroke-linecap="round"
															stroke-linejoin="round"
															d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"
														/>
													</svg>
												</span>
											</div>
											<!-- Content card -->
											<div class="min-w-0 flex-1 bg-mapa-canvas border border-mapa-contour/80 rounded-lg p-5 ml-4 hover:border-mapa-clay transition-colors duration-200">
												<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 border-b border-mapa-contour/40 pb-2.5 mb-3">
													<div class="flex items-center gap-3">
														<span class="uppercase text-[9px] font-bold tracking-wider px-2 py-0.5 rounded bg-mapa-green/10 text-mapa-green border border-mapa-green/20 select-none">
															{entry.version}
														</span>
														<h3 class="font-serif text-base font-bold text-mapa-ink">
															{entry.title}
														</h3>
													</div>
													<time
														datetime={entry.date}
														class="text-xs text-mapa-clay font-medium whitespace-nowrap"
													>
														{new Date(entry.date).toLocaleDateString("en-US", {
															month: "long",
															day: "numeric",
															year: "numeric",
														})}
													</time>
												</div>
												<p class="text-xs sm:text-sm text-mapa-ink/80 leading-relaxed">
													{entry.description}
												</p>
											</div>
										</div>
									</div>
								</li>
							))
						}
					</ul>
				</div>
			</div>
		</div>
	</div>
</section>
