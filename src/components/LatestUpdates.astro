---
/**
 * @file LatestUpdates.astro
 * @description Dynamic changelog section highlighting active development across the ecosystem.
 * Fetches latest releases from GitHub API at build time, with try/catch wrapping and a local cache fallback.
 */

import fallbackChangelog from "../data/changelog-fallback.json";

// List of repositories in the ecosystem that we track.
// Adding a new tool later is as simple as adding its 'owner/repo' string here.
// Note: Fetching our own release info ('Shiiroi/mapaph') during our own build is completely safe and correct.
// It is a read-only API call, not a build process depending on its own build output (no circular dependency risk).
const TRACKED_REPOS = ["Shiiroi/mapa", "Shiiroi/compaws", "Shiiroi/mapaph"];

// Structure of normalized release data used for UI rendering
interface ReleaseEntry {
	repo: string;
	repoName: string;
	version: string;
	date: string;
	title: string;
	description: string;
	url: string;
}

// Map tracked repo path to user-friendly project name for UI presentation
const REPO_NAME_MAP: Record<string, string> = {
	"Shiiroi/mapa": "Lens",
	"Shiiroi/compaws": "Compaws",
	"Shiiroi/mapaph": "Hub",
};

/**
 * Truncates markdown release descriptions to ~2-3 sentences.
 * Strips basic markdown structures for clean plain-text presentation in the timeline card.
 */
function cleanAndTruncateDescription(bodyText: string): string {
	if (!bodyText) return "";

	let text = bodyText
		.replace(/^#+\s+.+$/gm, "") // Remove headers
		.replace(/\[([^\]]+)\]\([^)]+\)/g, "$1") // Simplify markdown links to just their label
		.replace(/[*_`~]/g, "") // Strip formatting symbols
		.replace(/^\s*[-*+]\s+/gm, "") // Strip bullets
		.replace(/^\s*>\s+/gm, "") // Strip blockquotes
		.replace(/\s+/g, " ") // Normalize spaces
		.trim();

	// Match sentences ending in punctuation
	const sentences = text.match(/[^.!?]+[.!?]+/g) || [text];
	const truncated = sentences.slice(0, 3).join(" ").trim();

	if (sentences.length > 3) {
		return truncated + "...";
	}
	return truncated || "View the release page on GitHub for full details.";
}

const releases: ReleaseEntry[] = [];

// Fetch latest release details for each repository at build time.
// Note: We use GITHUB_API_TOKEN to get a higher rate limit (5,000 requests/hour) in CI/Vercel.
const apiToken = import.meta.env.GITHUB_API_TOKEN;

for (const repo of TRACKED_REPOS) {
	try {
		// Fetch with standard User-Agent header (required by GitHub) and authenticated token if available
		const headers: Record<string, string> = {
			"User-Agent": "mapaph-hub-builder",
		};
		if (apiToken) {
			headers["Authorization"] = `Bearer ${apiToken}`;
		}

		const response = await fetch(
			`https://api.github.com/repos/${repo}/releases/latest`,
			{
				headers,
			},
		);

		if (!response.ok) {
			throw new Error(`GitHub API returned status ${response.status}`);
		}

		const data = await response.json();

		releases.push({
			repo,
			repoName: REPO_NAME_MAP[repo] || repo,
			version: data.tag_name || "v0.0.0",
			date: data.published_at || new Date().toISOString(),
			title: data.name || "Release",
			description: cleanAndTruncateDescription(data.body),
			url: data.html_url || `https://github.com/${repo}/releases`,
		});
	} catch (error) {
		// Log warning but DO NOT fail the build. A flaky third-party API must not crash our production site.
		console.warn(
			`[Changelog Sync] Failed to fetch release details for '${repo}'. Falling back to local snapshot.`,
			error,
		);

		// Fallback to the local cache snapshot
		const cached = (fallbackChangelog as any)[repo];
		if (cached) {
			releases.push({
				repo,
				repoName: REPO_NAME_MAP[repo] || repo,
				version: cached.version,
				date: cached.date,
				title: cached.title,
				description: cached.description,
				url: cached.url,
			});
		} else {
			// Extremely safe backup if both API and fallback fail
			releases.push({
				repo,
				repoName: REPO_NAME_MAP[repo] || repo,
				version: "v0.0.0",
				date: new Date().toISOString(),
				title: "Release Pending",
				description: "Release information is temporarily unavailable.",
				url: `https://github.com/${repo}`,
			});
		}
	}
}

// Sort compiled releases newest first across all tracked repositories
releases.sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<section
	id="updates"
	class="bg-mapa-canvas-dark border-t border-mapa-contour/60 py-16 md:py-24 font-serif"
>
	<div class="max-w-7xl mx-auto px-6 lg:px-8">
		<div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16">
			<!-- Left Column: Title / Header -->
			<div class="lg:col-span-4 flex flex-col justify-start">
				<div class="flex items-center gap-2 mb-4">
					<span
						class="font-sans text-xs font-bold uppercase tracking-wider text-mapa-green"
					>
						Activity Log
					</span>
				</div>
				<h2
					class="text-3xl sm:text-4xl font-extrabold text-mapa-ink leading-tight"
				>
					Latest Updates & Releases
				</h2>
				<p class="font-sans text-sm text-mapa-ink/80 mt-4 leading-relaxed">
					Follow the latest progress, releases, and development milestones
					across all open-source tools in the mapaPH ecosystem.
				</p>
			</div>

			<!-- Right Column: Timeline list -->
			<div class="lg:col-span-8">
				<div class="flow-root font-sans">
					<ul class="-mb-8">
						{
							releases.map((entry, entryIdx) => (
								<li>
									<div class="relative pb-8">
										{entryIdx !== releases.length - 1 ? (
											<span
												class="absolute top-5 left-5 -ml-px h-full w-0.5 bg-mapa-contour"
												aria-hidden="true"
											/>
										) : null}
										<div class="relative flex items-start space-x-3">
											<!-- Timeline node dot -->
											<div class="relative">
												<span class="flex h-10 w-10 items-center justify-center rounded-full bg-mapa-green text-mapa-canvas ring-8 ring-mapa-canvas-dark">
													<svg
														xmlns="http://www.w3.org/2000/svg"
														fill="none"
														viewBox="0 0 24 24"
														stroke-width="2.5"
														stroke="currentColor"
														class="h-4.5 w-4.5"
													>
														<path
															stroke-linecap="round"
															stroke-linejoin="round"
															d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"
														/>
													</svg>
												</span>
											</div>
											<!-- Content card -->
											<div class="min-w-0 flex-1 bg-mapa-canvas border border-mapa-contour/80 rounded-lg p-5 ml-4 hover:border-mapa-clay transition-colors duration-200">
												<div class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-2 border-b border-mapa-contour/40 pb-2.5 mb-3">
													<div class="flex items-center gap-3">
														<a
															href={entry.url}
															target="_blank"
															rel="noopener noreferrer"
															class="uppercase text-[9px] font-bold tracking-wider px-2 py-0.5 rounded bg-mapa-green/10 text-mapa-green border border-mapa-green/20 hover:bg-mapa-green/20 transition-all select-none"
														>
															{entry.repoName} {entry.version}
														</a>
														<h3 class="font-serif text-base font-bold text-mapa-ink">
															{entry.title}
														</h3>
													</div>
													<time
														datetime={entry.date}
														class="text-xs text-mapa-clay font-medium whitespace-nowrap"
													>
														{new Date(entry.date).toLocaleDateString("en-US", {
															month: "long",
															day: "numeric",
															year: "numeric",
														})}
													</time>
												</div>
												<p class="text-xs sm:text-sm text-mapa-ink/80 leading-relaxed">
													{entry.description}
												</p>
											</div>
										</div>
									</div>
								</li>
							))
						}
					</ul>
				</div>
			</div>
		</div>
	</div>
</section>
