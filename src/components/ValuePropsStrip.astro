---
const props = [
	{
		title: "Open Data",
		description: "Access open geographic datasets and civic data tools built for transparency, allowing anyone to download, analyze, and use mapping resources freely.",
		// Database icon
		svg: `<svg class="w-6 h-6 text-mapa-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
			<path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4m0 5c0 2.21-3.582 4-8 4s-8-1.79-8-4" />
		</svg>`
	},
	{
		title: "Community Built",
		description: "Powered by community contributions, local knowledge, and open-source collaboration to construct highly-detailed resources that reflect the real ground reality.",
		// Users sharing icon
		svg: `<svg class="w-6 h-6 text-mapa-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
			<path stroke-linecap="round" stroke-linejoin="round" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
		</svg>`
	},
	{
		title: "Locally Grounded",
		description: "Tailored specifically to the unique nuances, language, and transport networks of local Philippine municipalities and communities.",
		// Map pin icon
		svg: `<svg class="w-6 h-6 text-mapa-green" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
			<path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
			<path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
		</svg>`
	}
];
---

<section class="bg-mapa-canvas-dark border-y border-mapa-contour/40 py-12 md:py-16">
	<div class="max-w-7xl mx-auto px-6 lg:px-8">
		<div class="grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
			{props.map((prop) => (
				<div class="flex flex-col items-start gap-4">
					<!-- Icon container -->
					<div class="w-10 h-10 rounded-full bg-mapa-canvas flex items-center justify-center border border-mapa-contour/30 shadow-sm">
						<Fragment set:html={prop.svg} />
					</div>
					
					<!-- Content -->
					<div>
						<h3 class="font-serif text-lg font-bold text-mapa-ink">
							{prop.title}
						</h3>
						<p class="font-sans text-sm text-mapa-ink/80 mt-2 leading-relaxed">
							{prop.description}
						</p>
					</div>
				</div>
			))}
		</div>
	</div>
</section>
