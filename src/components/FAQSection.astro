---
/**
 * @file FAQSection.astro
 * @description FAQ section with answers to common questions about the mapaPH hub,
 * focusing on open-source contributions, data practices, privacy, and licensing.
 * Includes interactive details/summary accordion elements and schema.org JSON-LD structured data.
 */

const faqs = [
	{
		question: "What is the purpose of mapaPH?",
		answer:
			"mapaPH serves as a central index and directory for open-source web applications built around maps of the Philippines. We focus on building simple, accessible tools for transit, directories, and geographic data visualizers to make spatial data more approachable for developers and the public.",
	},
	{
		question: "Can I use the data or code for my own projects?",
		answer:
			"Yes! All projects, source code repositories, and boundary data assets listed on mapaPH are open-source and licensed under the MIT license. You are free to inspect, fork, and build on top of our code for both personal and commercial use.",
	},
	{
		question: "How does open-source contribution work?",
		answer:
			"All our applications are hosted publicly on GitHub. Anyone is welcome to contribute to the codebase by opening issues, suggesting features, or submitting Pull Requests. You can find active repository links under each tool card in our directory.",
	},
	{
		question: "How is crowdsourced data verified and managed?",
		answer:
			"For directory-based tools, listings are suggested by the community. We maintain transparency by managing these submissions via open public repository files (like JSON/YAML configurations), which are verified before being merged.",
	},
	{
		question: "How does mapaPH collect and handle data?",
		answer:
			"We prioritize lightweight, public data resources (such as census data, regional code indexes, and publicly mapped coordinates). We do not collect, scrape, or monetize private geographic user tracking data.",
	},
	{
		question: "How is user privacy and tracking handled?",
		answer:
			"The main mapaPH hub website is fully static and does not use tracking cookies. While future ad integrations (like Google AdSense) may set cookies to serve ads, the core applications focus on minimizing telemetry and respecting user privacy.",
	},
];

// Generate JSON-LD schema objects for structured SEO rich results
// Why: Providing structured JSON-LD turns our FAQ text additions into rich, search-visible structured content
// that Google can understand and present as organic rich snippets (collapsible Q&A panels) in search results.
const jsonLd = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	mainEntity: faqs.map((faq) => ({
		"@type": "Question",
		name: faq.question,
		acceptedAnswer: {
			"@type": "Answer",
			text: faq.answer,
		},
	})),
};
---

<section
	id="faq"
	class="bg-mapa-canvas border-t border-mapa-contour/60 py-16 md:py-24 font-serif"
>
	<div class="max-w-4xl mx-auto px-6 lg:px-8">
		<!-- Section Header -->
		<div class="border-b border-mapa-contour/50 pb-5 mb-8 text-center">
			<span
				class="font-sans text-xs font-bold uppercase tracking-wider text-mapa-green"
			>
				FAQ
			</span>
			<h2
				class="text-3xl font-extrabold text-mapa-ink tracking-tight sm:text-4xl mt-2"
			>
				Frequently Asked Questions
			</h2>
			<p class="font-sans text-sm text-mapa-clay mt-1">
				Everything you need to know about the mapaPH ecosystem, data sources,
				and tools.
			</p>
		</div>

		<!-- Accordion Q&A list -->
		<div class="divide-y divide-mapa-contour/50">
			{
				faqs.map((faq) => (
					<details class="group py-5 [&_summary::-webkit-details-marker]:hidden">
						<summary class="flex justify-between items-center font-serif text-base sm:text-lg font-bold text-mapa-ink cursor-pointer list-none select-none hover:text-mapa-green transition-colors duration-200">
							<span>{faq.question}</span>
							<span class="ml-4 flex-shrink-0 transition-transform duration-300 group-open:rotate-180 text-mapa-clay">
								<svg
									xmlns="http://www.w3.org/2000/svg"
									class="h-5 w-5"
									fill="none"
									viewBox="0 0 24 24"
									stroke="currentColor"
									stroke-width="2"
								>
									<path
										stroke-linecap="round"
										stroke-linejoin="round"
										d="M19 9l-7 7-7-7"
									/>
								</svg>
							</span>
						</summary>
						<div class="mt-3 text-sm text-mapa-ink/80 leading-relaxed font-sans">
							<p>{faq.answer}</p>
						</div>
					</details>
				))
			}
		</div>
	</div>
</section>

<!-- 
	FAQ JSON-LD Structured Data - Can be placed anywhere in the document (body or head) 
	as per Google Search specifications. Safe to render inline.
-->
<script
	type="application/ld+json"
	is:inline
	set:html={JSON.stringify(jsonLd)}
/>
