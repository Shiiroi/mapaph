---
/**
 * @file FAQSection.astro
 * @description FAQ section with answers to common questions about mapaPH tools, data, and contributions.
 * Includes schema.org JSON-LD structured data for rich search results.
 */

const faqs = [
	{
		question: "What is mapaPH?",
		answer:
			"mapaPH is an open-source, community-driven mapping hub dedicated to building geographic, transit, and civic visualization tools for the Philippines. Our goal is to make spatial and regional data more accessible to developers, planners, and the public.",
	},
	{
		question: "What data sources power the Lens tool?",
		answer:
			"Lens displays geographical boundaries and demographic statistics using data sourced from the Philippine Statistics Authority (PSA), the National Mapping and Resource Information Authority (NAMRIA), and OpenStreetMap contributors.",
	},
	{
		question: "What does PSGC stand for and why is it used?",
		answer:
			"PSGC stands for Philippine Standard Geographic Code. It is a systematic classification used to code and organize regions, provinces, municipalities, cities, and barangays in the Philippines, ensuring standardized identifier indexing across all our tools.",
	},
	{
		question: "Are the mapping tools on mapaPH free to use?",
		answer:
			"Yes, all public client tools and boundary files generated by mapaPH are free and open-source under the MIT license. We plan to keep the core directory and search tools completely free, while any potential future APIs for high-volume enterprise geocoding will support the server hosting costs.",
	},
	{
		question: "How do contributions and crowd-sourcing work?",
		answer:
			"Our codebase is open for contributions on GitHub. For directory data like Compaws (animal-welcoming spots), we will support direct public crowd-sourcing where users can suggest edits or submit new listings via GitHub pull requests or visual reporting forms.",
	},
	{
		question: "How is transit data collected for the To-Cubao tool?",
		answer:
			"Transit routes and terminal coordinates are mapped based on Department of Transportation (DOTr) datasets combined with community-contributed commuter routing information and verified field walks.",
	},
];

// Generate JSON-LD schema objects for structured SEO rich results
// Why: Providing structured JSON-LD turns our FAQ text additions into rich, search-visible structured content
// that Google can understand and present as organic rich snippets (collapsible Q&A panels) in search results.
const jsonLd = {
	"@context": "https://schema.org",
	"@type": "FAQPage",
	mainEntity: faqs.map((faq) => ({
		"@type": "Question",
		name: faq.question,
		acceptedAnswer: {
			"@type": "Answer",
			text: faq.answer,
		},
	})),
};
---

<section
	id="faq"
	class="bg-mapa-canvas border-t border-mapa-contour/60 py-16 md:py-24 font-serif"
>
	<div class="max-w-7xl mx-auto px-6 lg:px-8">
		<!-- Section Header -->
		<div class="border-b border-mapa-contour/50 pb-5 mb-10">
			<span
				class="font-sans text-xs font-bold uppercase tracking-wider text-mapa-green"
			>
				FAQ
			</span>
			<h2
				class="text-3xl font-extrabold text-mapa-ink tracking-tight sm:text-4xl mt-2"
			>
				Frequently Asked Questions
			</h2>
			<p class="font-sans text-sm text-mapa-clay mt-1">
				Everything you need to know about the mapaPH ecosystem, data sources,
				and tools.
			</p>
		</div>

		<!-- Q&A Grid -->
		<div class="grid grid-cols-1 md:grid-cols-2 gap-8 lg:gap-12 font-sans">
			{
				faqs.map((faq) => (
					<div class="flex flex-col">
						<h3 class="font-serif text-lg font-bold text-mapa-ink">
							{faq.question}
						</h3>
						<p class="text-sm text-mapa-ink/80 mt-2.5 leading-relaxed">
							{faq.answer}
						</p>
					</div>
				))
			}
		</div>
	</div>
</section>

<!-- 
	FAQ JSON-LD Structured Data - Can be placed anywhere in the document (body or head) 
	as per Google Search specifications. Safe to render inline.
-->
<script
	type="application/ld+json"
	is:inline
	set:html={JSON.stringify(jsonLd)}
/>
